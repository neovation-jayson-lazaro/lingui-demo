    "babel-plugin-macros": "^3.1.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^29.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
